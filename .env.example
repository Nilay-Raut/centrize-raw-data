# Campaign Data Platform — Environment Variables
# Copy to .env and fill in all values before running.
# NEVER commit .env to git.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=postgres://cdp_user:cdp_password@localhost:5432/campaign_data

# Connection pool
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_byte_random_hex_string

# How long admin JWTs stay valid
JWT_EXPIRES_IN=8h

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (no trailing slashes)
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# Comma-separated list of IPs allowed to use the /api/export route
# Add the IP of any machine that will run bulk exports
ADMIN_IP_ALLOWLIST=127.0.0.1,::1

# ── Worker ────────────────────────────────────────────────────────────────────
# Number of concurrent BullMQ jobs the worker processes at once
WORKER_CONCURRENCY=3

# ── Upload ────────────────────────────────────────────────────────────────────
# Max upload file size in bytes (default: 50MB)
UPLOAD_MAX_BYTES=52428800

# ── Logging ───────────────────────────────────────────────────────────────────
# Levels: error | warn | info | debug
LOG_LEVEL=info

USE_S3="false"
