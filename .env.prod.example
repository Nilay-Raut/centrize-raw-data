# ── Connection Strings ────────────────────────────────────────────────────────
# Required by src/config/env.ts
DATABASE_URL=postgres://cdp:change_me_strong_password@cdp-db:5432/campaign_data
REDIS_URL=redis://cdp-redis:6379

# ── Postgres Credentials (used by docker-compose services) ────────────────────
POSTGRES_DB=campaign_data
POSTGRES_USER=cdp
POSTGRES_PASSWORD=change_me_strong_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRES_IN=8h

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated — your EC2 public IP or domain
ALLOWED_ORIGINS=http://your-ec2-ip,https://yourdomain.com

# IP allowlist for /api/export — office/VPN IPs only
ADMIN_IP_ALLOWLIST=your.office.ip.here

# ── S3 (Optional - Set USE_S3="true" to enable) ───────────────────────────────
USE_S3="false"
S3_BUCKET=your-bucket-name
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Worker & Tuning ───────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
UPLOAD_MAX_BYTES=52428800
LOG_LEVEL=info
NODE_ENV=production
