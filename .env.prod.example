# Copy this to .env.prod and fill in values
# NEVER commit .env.prod to git

# ── Postgres (used by docker-compose.prod.yml) ────────────────────────────────
POSTGRES_DB=campaign_data
POSTGRES_USER=cdp
POSTGRES_PASSWORD=change_me_strong_password

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=replace_with_64_char_hex_secret
JWT_EXPIRES_IN=8h

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated — your EC2 public IP or domain
ALLOWED_ORIGINS=http://your-ec2-ip,https://yourdomain.com

# IP allowlist for /api/export — office/VPN IPs only
ADMIN_IP_ALLOWLIST=your.office.ip.here

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET=your-bucket-name
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=2

# ── Tuning ────────────────────────────────────────────────────────────────────
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=5
LOG_LEVEL=info

USE_S3="false"
