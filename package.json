{
  "name": "campaign-data-platform",
  "version": "1.0.0",
  "description": "Campaign contact data ingestion, normalisation, and query API",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "dev:worker": "nodemon --exec ts-node src/workers/workerBoot.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/workerBoot.js",
    "migrate": "ts-node src/db/migrate.ts",
    "migrate:rollback": "ts-node src/db/migrate.ts rollback",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "test": "cross-env NODE_ENV=test jest --passWithNoTests",
    "test:watch": "jest --watch",
    "generate:key": "ts-node scripts/generateApiKey.ts",
    "test:coverage": "jest --coverage",
    "start:frontend": "nx serve admin-portal",
    "start:widget": "nx serve embed-widget"
  },
  "dependencies": {
    "@angular/animations": "^18.0.0",
    "@angular/cdk": "^18.0.0",
    "@angular/common": "^18.0.0",
    "@angular/compiler": "^18.0.0",
    "@angular/core": "^18.0.0",
    "@angular/elements": "^18.0.0",
    "@angular/forms": "^18.0.0",
    "@angular/platform-browser": "^18.0.0",
    "@angular/platform-browser-dynamic": "^18.0.0",
    "@angular/router": "^18.0.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "^3.1024.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.4.2",
    "cors": "^2.8.5",
    "dayjs": "^1.11.10",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-jwt": "^8.4.1",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "fast-csv": "^5.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.4.1",
    "pg": "^8.11.5",
    "pg-query-stream": "^4.14.0",
    "rate-limit-redis": "^4.2.0",
    "rxjs": "^7.8.1",
    "toobusy-js": "^0.5.1",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "xlsx": "^0.18.5",
    "zone.js": "^0.14.4"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^18.0.0",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^18.0.0",
    "@nx/angular": "22.6.3",
    "@nx/eslint-plugin": "22.6.3",
    "@nx/jest": "22.6.3",
    "@nx/js": "22.6.3",
    "@nx/workspace": "22.6.3",
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/hpp": "^0.2.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/papaparse": "^5.3.14",
    "@types/supertest": "^7.2.0",
    "@types/toobusy-js": "^0.5.4",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "nx": "22.6.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "5.4.5"
  }
}
